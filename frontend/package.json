{
  "name": "concinnity",
  "version": "1.1.1",
  "description": "Watch video files together with others on the internet.",
  "repository": "https://github.com/retrixe/concinnity.git",
  "author": "Ibrahim Ansari <ansari.ibrahim1@gmail.com>",
  "license": "AGPL-3.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "postinstall": "cd .. && husky frontend/.husky",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "yarn check && eslint --cache --cache-strategy content --cache-location .svelte-kit/ ."
  },
  "dependencies": {
    "heliodor": "^0.0.10",
    "ky": "^1.14.3",
    "phosphor-svelte": "^3.1.0",
    "remarkable": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/remarkable": "^2.0.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass-embedded": "^1.98.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vite-plugin-devtools-json": "^1.0.0"
  }
}
